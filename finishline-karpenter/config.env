#!/bin/bash
# Karpenter Deployment Configuration
# Update these values before deployment

# Cluster Configuration
export CLUSTER_NAME="finishline-eks-cluster"
export AWS_REGION="us-east-1"
export AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query "Account" --output text)

# Karpenter Configuration
export KARPENTER_VERSION="1.8.6"
export KARPENTER_NAMESPACE="karpenter"
export SERVICE_ACCOUNT_NAME="karpenter"
export KARPENTER_CONTROLLER_ROLE="KarpenterControllerRole"
export INTERRUPTION_QUEUE_NAME="${CLUSTER_NAME}-karpenter-interruption-queue"

# CloudFormation Stack
export STACK_NAME="Karpenter-${CLUSTER_NAME}"

# Node Configuration
export NODE_INSTANCE_TYPES="t3.large,t3a.large,m5.large,m5a.large"
export NODE_VOLUME_SIZE=20
export NODE_VOLUME_TYPE="gp3"
export AMI_FAMILY="Bottlerocket"

# NodePool Configuration
export CPU_LIMIT=20
export CAPACITY_TYPE="on-demand"

# Subnet and Security Group Tags
export DISCOVERY_TAG_KEY="karpenter.sh/discovery"
export DISCOVERY_TAG_VALUE="${CLUSTER_NAME}"
